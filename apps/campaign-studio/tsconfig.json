{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@studio/*": [
        "../../studio/src/*"
      ]
    }
  },
  "include": [
    "src",
    "../../studio/src/personalization/generate/orchestrate.ts",
    "../../studio/src/personalization/generate/ids.ts",
    "../../studio/src/personalization/generate/agentGenerate.ts",
    "../../studio/src/personalization/generate/promptAssembly.ts",
    "../../studio/src/personalization/generate/tokens.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/node_modules"
  ]
}
