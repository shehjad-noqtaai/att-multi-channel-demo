# Sanity Studio — used by `sanity deploy`, `sanity schema deploy`, and scripts/smoke.ts
# Copy to .env in this directory.

# Editor or deploy token (read + write for Generate / smoke; deploy-studio for hosting only)
SANITY_AUTH_TOKEN=

# Project identifiers (optional — already set in sanity.cli.ts and sanity.config.ts)
SANITY_STUDIO_PROJECT_ID=z6s0fz61
SANITY_STUDIO_DATASET=production
