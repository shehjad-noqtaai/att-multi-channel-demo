# AT&T Personalization — environment variables
#
# This monorepo uses workspace-specific env files. Copy each example to `.env`
# in the same directory:
#
#   cp apps/campaign-studio/.env.example apps/campaign-studio/.env
#   cp studio/.env.example studio/.env
#
# See README.md § Run locally / Deploy for details.

# ── apps/campaign-studio/.env ──────────────────────────────────────────────
# VITE_SANITY_PROJECT_ID=z6s0fz61
# VITE_SANITY_DATASET=production

# ── studio/.env ─────────────────────────────────────────────────────────────
# SANITY_AUTH_TOKEN=              # required for deploy & smoke test
# SANITY_STUDIO_PROJECT_ID=z6s0fz61
# SANITY_STUDIO_DATASET=production
